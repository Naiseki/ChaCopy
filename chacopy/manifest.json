{
  "manifest_version": 3,
  "name": "ChaCopy BETA",
  "version": "0.1.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-C5zqIFaP.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "resources": [
        "img/chacopy_icon48.png"
      ]
    }
  ],
  "icons": {
    "48": "img/chacopy_icon48.png",
    "128": "img/chacopy_icon128.png"
  },
  "action": {
    "default_title": "ChaCopy BETA"
  }
}
