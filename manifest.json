{
  "manifest_version": 3,
  "name": "ChaCopy",
  "version": "0.1.0",
  "description": "Copy ChatGPT messages as clean Markdown",
  "permissions": ["clipboardWrite"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["img/copy_btn.png"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ],
  "action": {
    "default_title": "ChaCopy"
  }
}

