{
  "manifest_version": 3,
  "name": "ChaCopy BETA",
  "version": "0.1.1",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["img/chacopy_icon48.png"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ],
    "icons": {
    "48": "img/chacopy_icon48.png",
    "128": "img/chacopy_icon128.png"
  },
  "action": {
    "default_title": "ChaCopy BETA"
  }
}

